<view class="container">
  <view wx:if="{{isGuest}}" class="guest-hero">
    <view class="guest-badge">客户版访客界面</view>
    <text class="guest-hero-title">欢迎先体验报修流程</text>
    <text class="guest-hero-desc">现在可直接浏览客户首页、填写报修信息。提交工单、查看个人订单、账户信息等需要身份的操作时，再完成微信登录/注册即可。</text>

    <view class="guest-action-row">
      <button class="guest-btn primary" bindtap="goNewOrder">立即体验报修</button>
      <button class="guest-btn secondary" bindtap="goAuthEntry">微信登录 / 注册</button>
    </view>

    <view class="guest-switch" bindtap="goTechnicianExperience">切换到师傅体验</view>
  </view>

  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.pending}}</text>
      <text class="stat-label">未完工单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.balance}}</text>
      <text class="stat-label">可用金额</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.frozen}}</text>
      <text class="stat-label">冻结金额</text>
    </view>
  </view>
<view class="menu-wrapper card">
  <!-- 功能入口 -->
  <view class="grid">
    <view class="grid-item" bindtap="goNewOrder">
      <image class="icon" mode="aspectFit" src="/assets/icons/new_order.png"></image>
      <text class="label">新建工单</text>
    </view>
    <view class="grid-item" bindtap="goRecharge">
      <image class="icon" mode="aspectFit" src="/assets/icons/recharge.png"></image>
      <text class="label">账户充值</text>
    </view>
    <view class="grid-item" bindtap="goRecords">
      <image class="icon" mode="aspectFit" src="/assets/icons/my_orders.png"></image>
      <text class="label">我的工单</text>
    </view>
    <view class="grid-item" bindtap="goEvaluate">
      <image class="icon" mode="aspectFit" src="/assets/icons/evaluate.png"></image>
      <text class="label">工单评价</text>
    </view>
    <view class="grid-item" bindtap="goProfile">
      <image class="icon" mode="aspectFit" src="/assets/icons/my_account.png"></image>
      <text class="label">我的账户</text>
    </view>
    <view class="grid-item" bindtap="goComplaint">
      <image class="icon" mode="aspectFit" src="/assets/icons/feedback.png"></image>
      <text class="label">投诉建议</text>
    </view>
    <view class="grid-item" bindtap="goBills">
      <image class="icon" mode="aspectFit" src="/assets/icons/bill_detail.png"></image>
      <text class="label">账务明细</text>
    </view>
    <view class="grid-item" bindtap="goAbout">
      <image class="icon" mode="aspectFit" src="/assets/icons/about_us.png"></image>
      <text class="label">关于我们</text>
    </view>
  </view>
</view>

</view>
