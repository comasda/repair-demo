<view class="container">
  <view wx:if="{{isGuest}}" class="guest-hero">
    <view class="guest-badge">师傅版访客界面</view>
    <text class="guest-hero-title">欢迎先体验接单流程</text>
    <text class="guest-hero-desc">现在可直接浏览师傅端首页与接单流程。接单、查看个人工单、收益资料等需要身份的操作时，再完成微信登录/注册即可。</text>

    <view class="guest-action-row">
      <button class="guest-btn primary" bindtap="goTasks">立即体验接单</button>
      <button class="guest-btn secondary" bindtap="goAuthEntry">微信登录 / 注册</button>
    </view>

    <view class="guest-switch" bindtap="goCustomerExperience">切换到客户体验</view>
  </view>

  <!-- 顶部统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.pending}}</text>
      <text class="stat-label">待接工单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.completed}}</text>
      <text class="stat-label">已完成工单</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.income}}</text>
      <text class="stat-label">收益金额</text>
    </view>
  </view>

<view class="menu-wrapper card">
  <!-- 功能入口 -->
  <view class="grid">
    <view class="grid-item" bindtap="goTasks">
      <image class="icon" mode="aspectFit" src="/assets/icons/order_list.png"></image>
      <text class="label">工单列表</text>
    </view>
    <view class="grid-item" bindtap="gomyOrders">
      <image class="icon" mode="aspectFit" src="/assets/icons/my_orders.png"></image>
      <text class="label">我的工单</text>
    </view>
    <view class="grid-item" bindtap="goIncome">
      <image class="icon" mode="aspectFit" src="/assets/icons/income_log.png"></image>
      <text class="label">收益记录</text>
    </view>
    <view class="grid-item" bindtap="goProfile">
      <image class="icon" mode="aspectFit" src="/assets/icons/my_profile.png"></image>
      <text class="label">我的资料</text>
    </view>
    <view class="grid-item" bindtap="goEvaluate">
      <image class="icon" mode="aspectFit" src="/assets/icons/evaluate.png"></image>
      <text class="label">工单评价</text>
    </view>
    <view class="grid-item" bindtap="goComplaint">
      <image class="icon" mode="aspectFit" src="/assets/icons/complaint_handle.png"></image>
      <text class="label">投诉处理</text>
    </view>
    <view class="grid-item" bindtap="goBills">
      <image class="icon" mode="aspectFit" src="/assets/icons/bill_detail.png"></image>
      <text class="label">账务明细</text>
    </view>
    <view class="grid-item" bindtap="goAbout">
      <image class="icon" mode="aspectFit" src="/assets/icons/about_us.png"></image>
      <text class="label">关于我们</text>
    </view>
  </view>
</view>

</view>
