<view class="page">
  <view class="card">
  <view class="section-title">首次登录完善资料</view>

  <view class="row">
    <text>使用身份</text>
    <picker mode="selector" range="{{roles}}" value="{{roleIndex}}" bindchange="onRoleChange">
      <view class="picker">{{ roleText }}</view>
    </picker>
  </view>

  <view class="row">
    <text>昵称</text>
    <input
      type="nickname"
      placeholder="请输入昵称"
      value="{{displayName}}"
      bindinput="onNameInput"
      maxlength="20"
    />
  </view>

  <view class="tips">
    <view>1. 请选择当前登录身份：客户或师傅；</view>
    <view>2. 填写昵称：确认使用微信昵称或输入昵称；</view>
    <view>3. 点击下方按钮授权微信手机号；</view>
    <view>4. 完成后将立即创建账号并进入系统。</view>
  </view>

      <button
        class="submit-btn"
        type="primary"
        open-type="getPhoneNumber"
        bindgetphonenumber="handleGetPhoneNumber"
        loading="{{submitting}}"
      >
        {{submitting ? '提交中...' : '授权手机号并进入系统'}}
      </button>
    </view>
  <view class="safe-bottom" />
</view>
