.page {
  min-height: 100vh;
  padding: 36rpx 28rpx 56rpx;
  box-sizing: border-box;
  background:
    linear-gradient(180deg, #5b6df7 0rpx, #6d7cff 420rpx, #f3f4f6 421rpx, #f3f4f6 100%);
}

.hero {
  padding: 36rpx 12rpx 56rpx;
}

.hero-badge {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #eef2ff;
  font-size: 22rpx;
  line-height: 1;
}

.title {
  margin-top: 28rpx;
  font-size: 52rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.desc {
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.9);
}

.panel {
  margin-top: 8rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 34rpx 28rpx 30rpx;
  box-shadow: 0 20rpx 50rpx rgba(79, 70, 229, 0.12);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.section-tag {
  flex: none;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
  font-weight: 600;
}

.field-label {
  margin-top: 30rpx;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.guest-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #f8faff;
  border: 2rpx solid #e0e7ff;
  color: #111827;
  font-size: 30rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 34rpx;
  color: #818cf8;
}

.btn {
  width: 100%;
  min-height: 92rpx;
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  box-sizing: border-box;
}

.btn::after {
  border: none;
}

.btn-guest {
  color: #4f46e5;
  background: #eef2ff;
}

.btn-wechat {
  color: #ffffff;
  background: linear-gradient(90deg, #6366f1, #4f46e5);
  box-shadow: 0 12rpx 28rpx rgba(79, 70, 229, 0.25);
}

.divider {
  margin: 30rpx 0 8rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
}

.divider-text {
  color: #9ca3af;
  font-size: 24rpx;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.feature-item {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 24rpx;
}

.footer {
  margin-top: 28rpx;
  padding: 0 16rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6b7280;
}
